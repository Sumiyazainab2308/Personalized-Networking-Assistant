# ─────────────────────────────────────────────────────────────────────────────
# Application environment variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Application
APP_NAME=Personalized Networking Assistant
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS_STR=http://localhost:8501,http://127.0.0.1:8501

# Data persistence
DATA_DIR=data
HISTORY_FILE=history.json
PROFILES_FILE=profiles.json

# NLP Models (Hugging Face Hub IDs)
ZERO_SHOT_MODEL=facebook/bart-large-mnli
GENERATION_MODEL=gpt2
MAX_NEW_TOKENS=80
NUM_STARTERS=5
GENERATION_TEMPERATURE=0.85
GENERATION_TOP_P=0.92

# Wikipedia
WIKIPEDIA_LANGUAGE=en
WIKIPEDIA_SENTENCES=3
WIKIPEDIA_TIMEOUT=10

# History
MAX_HISTORY_ITEMS=1000
